[Component]
SolidDensity = 2.0 #RhoG
SolidThermalConductivity = 1.0 # k
LiquidDensity = 1.0 #RhoS
LiquidThermalConductivity = 1.0 #k

[Grid]
LowerLeft = 0 0
UpperRight = 1 1
Cells = 5 5

[TimeLoop]
TEnd = 1 
TOutput = 0.1

[Problem]
Name = macro-heat
EnableGravity = false #confirm

[BoundaryConditions]
BcTypeLeft = neumann
BcTypeRight = neumann
BcTypeTop = dirichlet
BcTypeBottom = dirichlet
BcLeft = 0
BcRight = 0
BcTop = 273
BcBootom = 400

[InitialConditions]
Temperature = 273
Phi = 0.5 # porosity
k = 1.0 # SolidThermalConductivity

